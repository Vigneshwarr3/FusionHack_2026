# AquiferWatch environment variables
# Copy to .env and fill in. Many values are reused from the parent Agricultural_Data_Analysis/.env.

# --- Reused from parent project (same RDS, same S3) ---
DATABASE_URL=postgresql+asyncpg://ag_app:PASSWORD@ag-dashboard.cvuu6ce8odqc.us-east-2.rds.amazonaws.com:5432/ag_dashboard
DATABASE_ENDPOINT=ag-dashboard.cvuu6ce8odqc.us-east-2.rds.amazonaws.com
AWS_REGION=us-east-2
S3_BUCKET=usda-analysis-datasets
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- USDA / external API keys (reused from parent) ---
QUICKSTATS_API_KEY=
NOAA_API_KEY=
USDA_MARS_API_KEY=

# --- AquiferWatch-specific (NEW) ---
# USGS doesn't require a key for Water Services, but rate-limit politely
USGS_USER_AGENT=AquiferWatch/0.1 (raj@example.com)
# Kansas Geological Survey WIMAS — public CSV downloads; no key
KGS_WIMAS_BASE_URL=https://www.kgs.ku.edu/Magellan/WaterWell/
# Texas Water Development Board
TWDB_BASE_URL=https://www.twdb.texas.gov/groundwater/data/
# Nebraska DNR
NE_DNR_BASE_URL=https://dnr.nebraska.gov/

# --- MLflow ---
# Day 0: local SQLite + local artifact store
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_ARTIFACT_LOCATION=./mlartifacts
# Team mode (uncomment once shared server is up — see mlflow/README.md):
# MLFLOW_TRACKING_URI=postgresql://mlflow_user:PASSWORD@ag-dashboard.cvuu6ce8odqc.us-east-2.rds.amazonaws.com:5432/mlflow
# MLFLOW_ARTIFACT_LOCATION=s3://usda-analysis-datasets/aquiferwatch/mlartifacts

# --- Experiment metadata (ALWAYS SET — used as a tag on every run) ---
AQW_TEAM_MEMBER=raj
